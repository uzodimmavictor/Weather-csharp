<Window x:Class="WeatherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeatherApp"
        xmlns:viewmodels="clr-namespace:WeatherApp.ViewModels"
        xmlns:helpers="clr-namespace:WeatherApp.Helpers"
        mc:Ignorable="d"
        Title="Météo Provence"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <SolidColorBrush x:Key="WindowBackgroundBrush"
                         Color="#F0F4F8"/>
        <SolidColorBrush x:Key="CardBackgroundBrush"
                         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryTextBrush"
                         Color="#1F2937"/>
        <SolidColorBrush x:Key="SecondaryTextBrush"
                         Color="#6B7280"/>
        <SolidColorBrush x:Key="InputBackgroundBrush"
                         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBorderBrush"
                         Color="#D1D5DB"/>
        <SolidColorBrush x:Key="SectionBorderBrush"
                         Color="#E5E7EB"/>
        <SolidColorBrush x:Key="StatusBackgroundBrush"
                         Color="#E5E7EB"/>
        <SolidColorBrush x:Key="StatusTextBrush"
                         Color="#374151"/>
        <SolidColorBrush x:Key="ErrorBackgroundBrush"
                         Color="#FEE2E2"/>
        <SolidColorBrush x:Key="ErrorTextBrush"
                         Color="#DC2626"/>
        <SolidColorBrush x:Key="HoverBackgroundBrush"
                         Color="#F3F4F6"/>

        <Style x:Key="ModernButton"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#3B82F6"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Padding"
                    Value="20,10"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#9CA3AF"/>
                    <Setter Property="Cursor"
                            Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox"
               TargetType="TextBox">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Padding"
                    Value="12,10"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness"
                    Value="2"/>
            <Setter Property="Background"
                    Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused"
                         Value="True">
                    <Setter Property="BorderBrush"
                            Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius"
                    Value="12"/>
            <Setter Property="Padding"
                    Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="4"
                                      BlurRadius="15"
                                      Opacity="0.1"
                                      Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeToggleButton"
               TargetType="Button"
               BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background"
                    Value="#334155"/>
            <Setter Property="Content"
                    Value="🌙 Sombre"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDarkMode}"
                             Value="True">
                    <Setter Property="Content"
                            Value="☀️ Clair"/>
                    <Setter Property="Background"
                            Value="#F59E0B"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="☀️ Météo Provence"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Retrouvez notre beau soleil de Provence !"
                               FontSize="16"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchCity, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1"
                            Content="🔍 Rechercher"
                            Style="{StaticResource ModernButton}"
                            Command="{Binding SearchCommand}"
                            Margin="10,0,0,0"/>

                    <Button Grid.Column="2"
                            Content="⭐ Favori"
                            Command="{Binding AddToFavoritesCommand}"
                            Margin="10,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ModernButton}">
                                <Setter Property="Background"
                                        Value="#10B981"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#059669"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="3"
                            Content="❌ Retirer"
                            Command="{Binding RemoveFromFavoritesCommand}"
                            Margin="10,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ModernButton}">
                                <Setter Property="Background"
                                        Value="#EF4444"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#DC2626"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="4"
                            Style="{StaticResource ThemeToggleButton}"
                            Command="{Binding ToggleThemeCommand}"
                            Margin="10,0,0,0"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,20">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="⏳ Chargement en cours..."
                                       FontSize="18"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Background="{DynamicResource ErrorBackgroundBrush}"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                            Margin="0,0,0,20">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="14"
                                   Foreground="{DynamicResource ErrorTextBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding CurrentWeather, Converter={StaticResource NullToVisibilityConverter}}"
                            Margin="0,0,0,20">
                        <Grid DataContext="{Binding CurrentWeather}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        HorizontalAlignment="Center">
                                <TextBlock FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}">
                                    <Run Text="{Binding CityName}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding Country}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding DateTime, StringFormat='dd/MM/yyyy HH:mm'}"
                                           FontSize="14"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,20,0,0">
                                <TextBlock Text="{Binding TemperatureDisplay}"
                                           FontSize="72"
                                           FontWeight="Bold"
                                           Foreground="#3B82F6"/>
                                <StackPanel Margin="20,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DescriptionCapitalized}"
                                               FontSize="20"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <TextBlock FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}">
                                        <Run Text="Ressenti: "/>
                                        <Run Text="{Binding FeelsLike, StringFormat={}{0:F0}°C}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <UniformGrid Grid.Row="2"
                                         Columns="4"
                                         Margin="0,30,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="💧 Humidité"
                                               FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Humidity, StringFormat={}{0}%}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="💨 Vent"
                                               FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding WindSpeed, StringFormat={}{0:F1} m/s}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📊 Pression"
                                               FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Pressure, StringFormat={}{0} hPa}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🌡️ Min/Max"
                                               FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,5,0,0">
                                        <Run Text="{Binding TempMin, StringFormat={}{0:F0}°}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding TempMax, StringFormat={}{0:F0}°}"/>
                                    </TextBlock>
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding ForecastData, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="📅 Prévisions sur 5 jours"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,0,0,15"/>

                            <ItemsControl ItemsSource="{Binding ForecastData.Forecasts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource SectionBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DayName}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                    <TextBlock Text="{Binding DateDisplay}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Description}"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TempRangeDisplay}"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,20,0"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TempDisplay}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="#3B82F6"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Background="{DynamicResource StatusBackgroundBrush}"
                    CornerRadius="8"
                    Padding="15,10"
                    Margin="0,20,0,0"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           Foreground="{DynamicResource StatusTextBrush}"/>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="⭐ Villes Favorites"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FavoriteCities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource SectionBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,10"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.LoadFavoriteCityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding CityName}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding Country}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="🗑️"
                                                FontSize="16"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.DeleteFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                            Value="{DynamicResource HoverBackgroundBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
